# Resend (E-Mail-Versand)
# Account erstellen auf https://resend.com
RESEND_API_KEY=re_xxxxx

# Kunden-Mail: Absender-Domain (muss in Resend verifiziert sein)
# Kombiniert mit emailSenderLocal aus der DB → z.B. muster-solar@anfragebestaetigung.de
EMAIL_DOMAIN=anfragebestaetigung.de
EMAIL_FROM=noreply@anfragebestaetigung.de   # Fallback wenn emailSenderLocal nicht gesetzt

# Tenant-Mail: Plattform-Domain (Resend Pro erforderlich für 2. Domain)
# Wenn gesetzt → Tenant-Benachrichtigungen kommen von leads@diese-domain.de
# Wenn leer → selbe Domain wie Kunden-Mail (Resend Free kompatibel)
EMAIL_DOMAIN_PLATFORM=leadplug.de

# Deine eigene E-Mail für Billing-Tracking (Mail 3)
PLATFORM_OWNER_EMAIL=du@deine-email.de

# Supabase (Tracking & Billing)
# Projekt erstellen auf https://supabase.com → Settings → API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_KEY=eyJxxxxx   # "service_role" Key – NUR server-side!

# App-URL (für Links in E-Mails)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Passwort für /funnel-overview (Admin-Übersicht)
SITE_PASSWORD=geheim
