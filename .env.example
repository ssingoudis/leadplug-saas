# Resend (E-Mail-Versand)
# Account erstellen auf https://resend.com
RESEND_API_KEY=re_xxxxx

# Kunden-Mail: Absender-Domain (muss in Resend verifiziert sein)
# Kombiniert mit emailSenderLocal aus der DB → z.B. muster-solar@anfragebestaetigung.de
EMAIL_DOMAIN=anfragebestaetigung.de
EMAIL_FROM=noreply@anfragebestaetigung.de   # Fallback wenn emailSenderLocal nicht gesetzt

# Tenant-Mail: Plattform-Domain (Resend Pro erforderlich für 2. Domain)
# Wenn gesetzt → Tenant-Benachrichtigungen kommen von leads@diese-domain.de
# Wenn leer → selbe Domain wie Kunden-Mail
EMAIL_DOMAIN_PLATFORM=leadplug.de

# Supabase (Datenbank + Auth)
# Projekt erstellen auf https://supabase.com → Settings → API
SUPABASE_URL=https://xxxx.supabase.co          # Nur server-side (Service Key Client)
SUPABASE_SERVICE_KEY=eyJxxxxx                  # "service_role" Key – NUR server-side!

# Supabase Auth (öffentlich — sicher im Browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxxxx         # "anon" Key aus Supabase → Settings → API

# App-URL (für Links in E-Mails + OAuth-Redirect)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Superadmin-Schutz für /admin
# E-Mail-Adresse des Superadmin-Accounts in Supabase Auth
SUPERADMIN_EMAIL=deine@email.de

# Stripe Billing
# Test-Keys: https://dashboard.stripe.com/test/apikeys
# Produktion: Restricted API Key (rk_live_...) mit minimalen Rechten empfohlen
STRIPE_SECRET_KEY=sk_test_xxxxx
# Price-IDs aus Stripe Dashboard → Products
STRIPE_PRICE_ID_STANDARD=price_xxxxx
# Test-Produkt (1 €/Monat, sofortige Kündigung) — nur dev/staging
STRIPE_PRICE_ID_TEST=price_xxxxx
# Webhook-Signing-Secret (stripe listen → lokal | Stripe Dashboard → Produktion)
STRIPE_WEBHOOK_SECRET=whsec_xxxxx

# Beta-Feedback-Widget (Aufgabe 67)
# Empfänger der Feedback-Mails (z. B. Alias support@leadplug.de) — nur server-side.
SUPPORT_EMAIL=support@example.de
# WhatsApp-Schnelldraht im Feedback-Panel: internationale Ziffern ohne "+"
# (0157 56394048 → 4915756394048). Leer lassen = kein WhatsApp-Link.
NEXT_PUBLIC_SUPPORT_WHATSAPP=

# Webhook-Cron (Aufgabe 40)
# Auth-Token für /api/cron/webhook-retry — Vercel-Cron sendet
# "Authorization: Bearer $CRON_SECRET". Beliebiger 64-Zeichen-Hex empfohlen:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Production: gleichen Wert in Vercel ENV-Vars setzen (Settings → Environment).
CRON_SECRET=
